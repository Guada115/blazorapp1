@code {
    // Definimos las 15 listas independientes de forma explícita
    private List<TableRow> rows1 = new() { new TableRow() };
    private List<TableRow> rows2 = new() { new TableRow() };
    private List<TableRow> rows3 = new() { new TableRow() };
    private List<TableRow> rows4 = new() { new TableRow() };
    private List<TableRow> rows5 = new() { new TableRow() };
    private List<TableRow> rows6 = new() { new TableRow() };
    private List<TableRow> rows7 = new() { new TableRow() };
    private List<TableRow> rows8 = new() { new TableRow() };
    private List<TableRow> rows9 = new() { new TableRow() };
    private List<TableRow> rows10 = new() { new TableRow() };
    private List<TableRow> rows11 = new() { new TableRow() };
    private List<TableRow> rows12 = new() { new TableRow() };
    private List<TableRow> rows13 = new() { new TableRow() };
    private List<TableRow> rows14 = new() { new TableRow() };
    private List<TableRow> rows15 = new() { new TableRow() };

    public class TableRow
    {
        public string Dato1 { get; set; } = "";
        public string Dato2 { get; set; } = "";
        public string Dato3 { get; set; } = "";
        public string Dato4 { get; set; } = "";
        public string Dato5 { get; set; } = "";
        public string Dato6 { get; set; } = "";
    }
}
