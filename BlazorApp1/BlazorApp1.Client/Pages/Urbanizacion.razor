@page "/urbanizacion"
@rendermode InteractiveWebAssembly

<PageTitle>Urbanización</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4 text-center">Gestión de Urbanización</h1>

    <!-- TABLA 1: APARTAMENTOS -->
    <div class="card mb-5 border-primary shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title mb-0">1. Apartamentos</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px">#</th>
                            <th>Unidad</th>
                            <th>TorreId</th>
                            <th>Número</th>
                            <th>Tipo</th>
                            <th>Área</th>                            
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in rows1)
                        {
                            <tr>
                                <td>@(rows1.IndexOf(row) + 1)</td>
                                <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Unidad" /></td>
                                <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="TorreId" /></td>
                                <td><input type="text" class="form-control" @bind="row.Dato3" placeholder="Número" /></td>
                                <td><input type="text" class="form-control" @bind="row.Dato4" placeholder="Tipo" /></td>
                                <td><input type="text" class="form-control" @bind="row.Dato5" placeholder="Área" /></td>                               
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button class="btn btn-primary" @onclick="() => rows1.Add(new TableRow())">
                <i class="bi bi-save"></i> Guardar
            </button>
        </div>
    </div>

    <!-- TABLA 2: Bitacora vigilancia -->
    <div class="card mb-5 border-secondary shadow-sm">
        <div class="card-header bg-secondary text-white">
            <h3 class="card-title mb-0">2. Bitacora vigilancia</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-bordered align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px">#</th>
                            <th>Bitacora Id</th>
                            <th>Vigilante Id</th>
                            <th>Fecha Hora</th>
                            <th>Obsrvación</th>                            
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in rows2)
                        {
                            <tr>
                                <td>@(rows2.IndexOf(row) + 1)</td>
                                <td><input type="text" class="form-control" @bind="row.Dato1" /></td>
                                <td><input type="text" class="form-control" @bind="row.Dato2" /></td>
                                <td><input type="text" class="form-control" @bind="row.Dato3" /></td>
                                <td><input type="text" class="form-control" @bind="row.Dato4" /></td>                                
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <button class="btn btn-secondary" @onclick="() => rows2.Add(new TableRow())">
                Guardar
            </button>
        </div>
    </div>

    <!-- TABLA 3 -->
    <div class="card mb-5 border-info shadow-sm">
        <div class="card-header bg-info text-white">
            <h3 class="card-title mb-0">3. Conjunto</h3>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
