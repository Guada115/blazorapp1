@page "/urbanizacion/operaciones"
@rendermode InteractiveWebAssembly
@attribute [Authorize(Roles = "1,2,3")]
@inject HttpClient Http
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthStateProvider

<PageTitle>Operaciones - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Operaciones & Servicios</h1>
            <p class="text-muted mb-0">Gestión de áreas comunes, reservas y mantenimiento preventivo/correctivo.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 p-2 rounded-3 shadow-sm d-inline-flex border overflow-auto flex-nowrap w-100" style="background-color: var(--card-bg); border-color: rgba(255,255,255,0.05) !important;">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "reservas" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("reservas")'>
                <i class="bi bi-calendar-check me-2"></i> Reservas
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "zonas" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("zonas")'>
                <i class="bi bi-tree me-2"></i> Zonas Comunes
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "mantenimiento" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("mantenimiento")'>
                <i class="bi bi-tools me-2"></i> Mantenimientos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "tipos" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("tipos")'>
                <i class="bi bi-gear me-2"></i> Tipos Mant.
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "reservas")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex flex-wrap gap-3 align-items-end">
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Zona Común</label>
                        <select class="form-select form-select-sm" @bind="filtroZonaRes">
                            <option value="0">Todas</option>
                            @foreach (var z in zonaRows)
                            {
                                <option value="@z.ZonaComunId">@z.Nombre</option>
                            }
                        </select>
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Usuario</label>
                        <select class="form-select form-select-sm" @bind="filtroUsuarioRes">
                            <option value="0">Todos</option>
                            @foreach (var u in allUsuarios)
                            {
                                <option value="@u.UsuarioId">@u.Nombre</option>
                            }
                        </select>
                    </div>
                    <div style="width: 180px;">
                        <label class="form-label fw-bold small text-muted mb-1">Fecha</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtroFechaRes" />
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => { filtroZonaRes=0; filtroUsuarioRes=0; filtroFechaRes=null; }">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </button>
                </div>
            </div>
            <EntityTable TItem="Reserva"
                         Title="Listado de Reservas"
                         Headers='new() { "Zona Común", "Usuario", "Fecha", "Inicio", "Fin", "Estado", "Total Cobrar" }'
                         Items="FilteredReservaRows"
                         ShowReportButton="true" ReportEntity="reservas" RequiresDateRange="true"
                         ReadOnly="@isVigilante"
                         OnAddRow='() => AddRow(reservaRows)' OnSaveRow='SaveReserva'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.ZonaComunId" @bind:after="() => CalcularTotal(row)" disabled="@(isVigilante || (isResidente && row.ReservaId != 0))">
                            <option value="0">Seleccionar Zona...</option>
                            @foreach (var z in zonaRows)
                            {
                                <option value="@z.ZonaComunId">@z.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.UsuarioId" disabled="@(isVigilante || isResidente)">
                            <option value="0">Seleccionar Usuario...</option>
                            @foreach (var u in allUsuarios)
                            {
                                <option value="@u.UsuarioId">@u.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="date" class="form-control" @bind="row.Fecha" disabled="@(isVigilante || (isResidente && row.ReservaId != 0))" /></td>
                    <td><input type="time" class="form-control" @bind="row.HoraInicio" @bind:after="() => CalcularTotal(row)" disabled="@(isVigilante || (isResidente && row.ReservaId != 0))" /></td>
                    <td><input type="time" class="form-control" @bind="row.HoraFin" @bind:after="() => CalcularTotal(row)" disabled="@(isVigilante || (isResidente && row.ReservaId != 0))" /></td>
                    <td>
                        <select class="form-select" @bind="row.Estado" disabled="@(isVigilante || isResidente)">
                            <option value="reservado">Reservado</option>
                            <option value="disponible">Disponible</option>
                        </select>
                    </td>
                    <td>
                        <input type="number" class="form-control"
                               value="@row.TotalCobrar"
                               @onchange="@(e => { if(decimal.TryParse(e.Value?.ToString(), out var parsed)) row.TotalCobrar = parsed; else row.TotalCobrar = null; })"
                               placeholder="Total"
                               disabled="@(isVigilante || isResidente)" />
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "zonas")
        {
            <EntityTable TItem="ZonaComun"
                         Title="Zonas Comunes"
                         Headers='new() { "Nombre", "Requiere Pago", "Valor Hora" }'
                         Items="zonaRows"
                         ShowReportButton="true" ReportEntity="zonascomunes"
                         ReadOnly="@isReadOnly"
                         OnAddRow='() => AddRow(zonaRows)' OnSaveRow='SaveZonaComun'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" disabled="@isReadOnly" /></td>
                    <td>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" @bind="row.RequierePago" disabled="@isReadOnly" />
                        </div>
                    </td>
                    <td>
                        <input type="number" class="form-control"
                               value="@row.ValorHora"
                               @onchange="@(e => { if(int.TryParse(e.Value?.ToString(), out var parsed)) row.ValorHora = parsed; else row.ValorHora = null; })"
                               placeholder="Valor Hora"
                               disabled="@isReadOnly" />
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "mantenimiento")
        {
            <EntityTable TItem="Mantenimiento"
                         Title="Mantenimientos Programados"
                         Headers='new() { "Tipo", "Fecha", "Proveedor", "Descripción", "Costo", "Zona" }'
                         Items="mantenimientoRows"
                         ShowReportButton="true" ReportEntity="mantenimientos" RequiresDateRange="true"
                         ReadOnly="@isReadOnly"
                         OnAddRow='() => AddRow(mantenimientoRows)' OnSaveRow='SaveMantenimiento'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.TipoMantenimientoId" disabled="@isReadOnly">
                            <option value="0">Seleccionar Tipo...</option>
                            @foreach (var t in tipoRows)
                            {
                                <option value="@t.TipoMantenimientoId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="date" class="form-control" @bind="row.Fecha" disabled="@isReadOnly" /></td>
                    <td><input type="text" class="form-control" @bind="row.Provider" placeholder="Proveedor" disabled="@isReadOnly" /></td>
                    <td><input type="text" class="form-control" @bind="row.Descripcion" placeholder="Descripción" disabled="@isReadOnly" /></td>
                    <td><input type="number" class="form-control" @bind="row.Costo" placeholder="Costo" disabled="@isReadOnly" /></td>
                    <td>
                        <select class="form-select" @bind="row.ZonaComunId" disabled="@isReadOnly">
                            <option value="0">Seleccionar Zona...</option>
                            @foreach (var z in zonaRows)
                            {
                                <option value="@z.ZonaComunId">@z.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "tipos")
        {
            <EntityTable TItem="TipoMantenimiento"
                         Title="Tipos de Mantenimiento"
                         Headers='new() { "Nombre" }'
                         Items="tipoRows"
                         ShowReportButton="true" ReportEntity="tiposmantenimiento"
                         ReadOnly="@isReadOnly"
                         OnAddRow='() => AddRow(tipoRows)' OnSaveRow='SaveTipoMantenimiento'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" disabled="@isReadOnly" /></td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "reservas";
    private bool isResidente = false;
    private bool isVigilante = false;
    private bool isReadOnly => isResidente || isVigilante;
    private int currentUserId = 0;

    private List<Reserva> reservaRows = new();
    private List<ZonaComun> zonaRows = new();
    private List<Mantenimiento> mantenimientoRows = new();
    private List<TipoMantenimiento> tipoRows = new();
    private List<Usuario> allUsuarios = new();

    private int filtroZonaRes = 0;
    private int filtroUsuarioRes = 0;
    private DateTime? filtroFechaRes;

    private List<Reserva> FilteredReservaRows
    {
        get
        {
            var query = reservaRows.AsEnumerable();
            if (filtroZonaRes != 0) query = query.Where(r => r.ReservaId == 0 || r.ZonaComunId == filtroZonaRes);
            if (filtroUsuarioRes != 0) query = query.Where(r => r.ReservaId == 0 || r.UsuarioId == filtroUsuarioRes);
            if (filtroFechaRes.HasValue) query = query.Where(r => r.ReservaId == 0 || r.Fecha == DateOnly.FromDateTime(filtroFechaRes.Value));
            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var roleClaim = user.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
            if (roleClaim == "2") isResidente = true;
            if (roleClaim == "1") isVigilante = true;

            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (int.TryParse(idClaim, out int uid)) currentUserId = uid;
        }

        try
        {
            zonaRows = await Http.GetFromJsonAsync<List<ZonaComun>>("api/zonascomunes") ?? new();
            tipoRows = await Http.GetFromJsonAsync<List<TipoMantenimiento>>("api/tiposmantenimiento") ?? new();
            reservaRows = await Http.GetFromJsonAsync<List<Reserva>>("api/reservas") ?? new();
            mantenimientoRows = await Http.GetFromJsonAsync<List<Mantenimiento>>("api/mantenimientos") ?? new();
            var usus = await Http.GetFromJsonAsync<List<Usuario>>("api/usuarios") ?? new();
            allUsuarios = usus.Where(u => u.RolId == 2).ToList();
            PopularNombresReservas();

            if (zonaRows.Count == 0) zonaRows.Add(new ZonaComun());
            if (tipoRows.Count == 0) tipoRows.Add(new TipoMantenimiento());
            if (reservaRows.Count == 0) reservaRows.Add(new Reserva { UsuarioId = isResidente ? currentUserId : 0, Fecha = DateOnly.FromDateTime(DateTime.Now) });
            if (mantenimientoRows.Count == 0) mantenimientoRows.Add(new Mantenimiento { Fecha = DateOnly.FromDateTime(DateTime.Now) });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
            if (zonaRows.Count == 0) zonaRows.Add(new ZonaComun());
            if (tipoRows.Count == 0) tipoRows.Add(new TipoMantenimiento());
            if (reservaRows.Count == 0) reservaRows.Add(new Reserva { UsuarioId = isResidente ? currentUserId : 0, Fecha = DateOnly.FromDateTime(DateTime.Now) });
            if (mantenimientoRows.Count == 0) mantenimientoRows.Add(new Mantenimiento { Fecha = DateOnly.FromDateTime(DateTime.Now) });
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private void PopularNombresReservas()
    {
        foreach (var r in reservaRows)
        {
            r.ZonaNombre = zonaRows.FirstOrDefault(z => z.ZonaComunId == r.ZonaComunId)?.Nombre ?? "";
            r.UsuarioNombre = allUsuarios.FirstOrDefault(u => u.UsuarioId == r.UsuarioId)?.Nombre ?? "";
        }
    }

    private void AddRow<T>(List<T> target) where T : new()
    {
        var newItem = new T();
        if (newItem is Reserva r)
        {
            r.Estado = "reservado";
            r.Fecha = DateOnly.FromDateTime(DateTime.Now);
            r.HoraInicio = TimeOnly.FromDateTime(DateTime.Now.AddHours(1));
            r.HoraFin = TimeOnly.FromDateTime(DateTime.Now.AddHours(2));
            if (isResidente) r.UsuarioId = currentUserId;
        }
        target.Add(newItem);
    }

    private void CalcularTotal(Reserva row)
    {
        var zona = zonaRows.FirstOrDefault(z => z.ZonaComunId == row.ZonaComunId);
        if (zona != null && zona.RequierePago && zona.ValorHora.HasValue && zona.ValorHora.Value > 0)
        {
            var inicio = new TimeSpan(row.HoraInicio.Hour, row.HoraInicio.Minute, 0);
            var fin = new TimeSpan(row.HoraFin.Hour, row.HoraFin.Minute, 0);
            if (fin < inicio) fin = fin.Add(TimeSpan.FromHours(24));

            int totalMinutos = (int)(fin - inicio).TotalMinutes;
            int horasCompletas = totalMinutos / 60;
            int minutosRestantes = totalMinutos % 60;

            decimal total = horasCompletas * zona.ValorHora.Value;
            if (minutosRestantes >= 30)
                total += zona.ValorHora.Value / 2m;

            row.TotalCobrar = total;
        }
        else
        {
            row.TotalCobrar = 0;
        }
    }

    private async Task SaveReserva(Reserva reserva)
    {
        if (reserva.ReservaId == 0)
        {
            var reservaDateTime = reserva.Fecha.ToDateTime(reserva.HoraInicio);
            if (reservaDateTime <= DateTime.Now)
            {
                await JS.InvokeVoidAsync("alert", "La fecha y hora de inicio debe ser posterior a la actual.");
                return;
            }
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/reservas", reserva);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Reserva>();
                if (saved != null) reserva.ReservaId = saved.ReservaId;
                reserva.ZonaNombre = zonaRows.FirstOrDefault(z => z.ZonaComunId == reserva.ZonaComunId)?.Nombre ?? "";
                reserva.UsuarioNombre = allUsuarios.FirstOrDefault(u => u.UsuarioId == reserva.UsuarioId)?.Nombre ?? "";
                await JS.InvokeVoidAsync("alert", "Reserva guardada correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Reserva: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar Reserva. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveZonaComun(ZonaComun zona)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/zonascomunes", zona);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<ZonaComun>();
                if (saved != null) zona.ZonaComunId = saved.ZonaComunId;
                await JS.InvokeVoidAsync("alert", "Zona Común guardada correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Zona Común: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar Zona Común. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveMantenimiento(Mantenimiento mantenimiento)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/mantenimientos", mantenimiento);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Mantenimiento>();
                if (saved != null) mantenimiento.MantenimientoId = saved.MantenimientoId;
                await JS.InvokeVoidAsync("alert", "Mantenimiento guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Mantenimiento: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar Mantenimiento. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveTipoMantenimiento(TipoMantenimiento tipo)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/tiposmantenimiento", tipo);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<TipoMantenimiento>();
                if (saved != null) tipo.TipoMantenimientoId = saved.TipoMantenimientoId;
                await JS.InvokeVoidAsync("alert", "Tipo de Mantenimiento guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Tipo de Mantenimiento: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar Tipo de Mantenimiento. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }
}
