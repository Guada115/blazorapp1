@page "/urbanizacion/operaciones"
@rendermode InteractiveWebAssembly

<PageTitle>Operaciones - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Operaciones & Servicios</h1>
            <p class="text-muted mb-0">Gestión de áreas comunes, reservas y mantenimiento preventivo/correctivo.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 bg-white p-2 rounded-3 shadow-sm d-inline-flex border overflow-auto flex-nowrap w-100">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "reservas" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("reservas")'>
                <i class="bi bi-calendar-check me-2"></i> Reservas
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "zonas" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("zonas")'>
                <i class="bi bi-tree me-2"></i> Zonas Comunes
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "mantenimiento" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("mantenimiento")'>
                <i class="bi bi-tools me-2"></i> Mantenimientos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "tipos" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("tipos")'>
                <i class="bi bi-gear me-2"></i> Tipos Mant.
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "reservas")
        {
            <EntityTable TItem="TableRow"
                         Title="Listado de Reservas"
                         Headers='new() { "Reserva Id", "Zona Id", "Residente Id", "Fecha Hora" }'
                         Items="reservaRows"
                         OnAddRow='() => AddRow(reservaRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Reserva Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="Zona Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato3" placeholder="Residente Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato4" placeholder="Fecha Hora" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "zonas")
        {
            <EntityTable TItem="TableRow"
                         Title="Listado de Zonas"
                         Headers='new() { "Zona Id", "Nombre Zona", "Capacidad" }'
                         Items="zonaRows"
                         OnAddRow='() => AddRow(zonaRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Zona Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="Nombre Zona" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato3" placeholder="Capacidad" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "mantenimiento")
        {
            <EntityTable TItem="TableRow"
                         Title="Registro de Mantenimientos"
                         Headers='new() { "Id", "Nombre", "Tipo Id", "Costo" }'
                         Items="mantenimientoRows"
                         OnAddRow='() => AddRow(mantenimientoRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="Nombre" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato3" placeholder="Tipo Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato4" placeholder="Costo" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "tipos")
        {
            <EntityTable TItem="TableRow"
                         Title="Tipos de Mantenimiento"
                         Headers='new() { "Tipo Id", "Nombre" }'
                         Items="tipoRows"
                         OnAddRow='() => AddRow(tipoRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Tipo Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="Nombre" /></td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "reservas";
    
    private List<TableRow> reservaRows = new() { new TableRow() };
    private List<TableRow> zonaRows = new() { new TableRow() };
    private List<TableRow> mantenimientoRows = new() { new TableRow() };
    private List<TableRow> tipoRows = new() { new TableRow() };

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow(List<TableRow> target)
    {
        target.Add(new TableRow());
    }
}
