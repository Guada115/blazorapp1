@page "/urbanizacion/operaciones"
@rendermode InteractiveWebAssembly
@inject HttpClient Http

<PageTitle>Operaciones - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Operaciones & Servicios</h1>
            <p class="text-muted mb-0">Gestión de áreas comunes, reservas y mantenimiento preventivo/correctivo.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 bg-white p-2 rounded-3 shadow-sm d-inline-flex border overflow-auto flex-nowrap w-100">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "reservas" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("reservas")'>
                <i class="bi bi-calendar-check me-2"></i> Reservas
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "zonas" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("zonas")'>
                <i class="bi bi-tree me-2"></i> Zonas Comunes
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "mantenimiento" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("mantenimiento")'>
                <i class="bi bi-tools me-2"></i> Mantenimientos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "tipos" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("tipos")'>
                <i class="bi bi-gear me-2"></i> Tipos Mant.
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "reservas")
        {
            <EntityTable TItem="Reserva"
                         Title="Listado de Reservas"
                         Headers='new() { "Zona Común", "Usuario", "Fecha", "Inicio", "Fin", "Estado" }'
                         Items="reservaRows"
                         OnAddRow='() => AddRow(reservaRows)'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.ZonaComunId">
                            <option value="0">Seleccionar Zona...</option>
                            @foreach (var z in zonaRows)
                            {
                                <option value="@z.ZonaComunId">@z.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.UsuarioId">
                            <option value="0">Seleccionar Usuario...</option>
                            @foreach (var u in allUsuarios)
                            {
                                <option value="@u.UsuarioId">@u.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="date" class="form-control" @bind="row.Fecha" /></td>
                    <td><input type="time" class="form-control" @bind="row.HoraInicio" /></td>
                    <td><input type="time" class="form-control" @bind="row.HoraFin" /></td>
                    <td><input type="text" class="form-control" @bind="row.Estado" placeholder="Estado" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "zonas")
        {
            <EntityTable TItem="ZonaComun"
                         Title="Listado de Zonas Comunes"
                         Headers='new() { "Nombre", "Pago Requerido", "Valor Hora" }'
                         Items="zonaRows"
                         OnAddRow='() => AddRow(zonaRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                    <td>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" @bind="row.RequierePago" />
                        </div>
                    </td>
                    <td><input type="number" class="form-control" @bind="row.ValorHora" placeholder="Valor Hora" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "mantenimiento")
        {
            <EntityTable TItem="Mantenimiento"
                         Title="Registro de Mantenimientos"
                         Headers='new() { "Tipo", "Fecha", "Proveedor", "Descripción", "Costo", "Zona" }'
                         Items="mantenimientoRows"
                         OnAddRow='() => AddRow(mantenimientoRows)'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.TipoMantenimientoId">
                            <option value="0">Seleccionar Tipo...</option>
                            @foreach (var t in tipoRows)
                            {
                                <option value="@t.TipoMantenimientoId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="date" class="form-control" @bind="row.Fecha" /></td>
                    <td><input type="text" class="form-control" @bind="row.Provider" placeholder="Proveedor" /></td>
                    <td><input type="text" class="form-control" @bind="row.Descripcion" placeholder="Descripción" /></td>
                    <td><input type="number" class="form-control" @bind="row.Costo" placeholder="Costo" /></td>
                    <td>
                        <select class="form-select" @bind="row.ZonaComunId">
                            <option value="0">Seleccionar Zona...</option>
                            @foreach (var z in zonaRows)
                            {
                                <option value="@z.ZonaComunId">@z.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "tipos")
        {
            <EntityTable TItem="TipoMantenimiento"
                         Title="Tipos de Mantenimiento"
                         Headers='new() { "ID", "Nombre" }'
                         Items="tipoRows"
                         OnAddRow='() => AddRow(tipoRows)'>
                <RowTemplate Context="row">
                    <td><input type="number" class="form-control" @bind="row.TipoMantenimientoId" placeholder="ID" /></td>
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "reservas";
    
    private List<Reserva> reservaRows = new();
    private List<ZonaComun> zonaRows = new();
    private List<Mantenimiento> mantenimientoRows = new();
    private List<TipoMantenimiento> tipoRows = new();
    private List<Usuario> allUsuarios = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            zonaRows = await Http.GetFromJsonAsync<List<ZonaComun>>("api/zonascomunes") ?? new();
            tipoRows = await Http.GetFromJsonAsync<List<TipoMantenimiento>>("api/tiposmantenimiento") ?? new();
            reservaRows = await Http.GetFromJsonAsync<List<Reserva>>("api/reservas") ?? new();
            mantenimientoRows = await Http.GetFromJsonAsync<List<Mantenimiento>>("api/mantenimientos") ?? new();
            allUsuarios = await Http.GetFromJsonAsync<List<Usuario>>("api/usuarios") ?? new();
            
            if (zonaRows.Count == 0) zonaRows.Add(new ZonaComun());
            if (tipoRows.Count == 0) tipoRows.Add(new TipoMantenimiento());
            if (reservaRows.Count == 0) reservaRows.Add(new Reserva());
            if (mantenimientoRows.Count == 0) mantenimientoRows.Add(new Mantenimiento());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
            if (zonaRows.Count == 0) zonaRows.Add(new ZonaComun());
            if (tipoRows.Count == 0) tipoRows.Add(new TipoMantenimiento());
            if (reservaRows.Count == 0) reservaRows.Add(new Reserva());
            if (mantenimientoRows.Count == 0) mantenimientoRows.Add(new Mantenimiento());
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow<T>(List<T> target) where T : new()
    {
        target.Add(new T());
    }
}
