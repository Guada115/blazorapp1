@page "/urbanizacion/admin"
@rendermode InteractiveWebAssembly
@attribute [Authorize(Roles = "3")]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Administración - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Panel Administrativo</h1>
            <p class="text-muted mb-0">GestiÃ³n de la copropiedad, personal y niveles de acceso.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 p-2 rounded-3 shadow-sm d-inline-flex border" style="background-color: var(--card-bg); border-color: rgba(255,255,255,0.05) !important;">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "conjunto" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("conjunto")'>
                <i class="bi bi-houses me-2"></i> Conjunto
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "usuarios" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("usuarios")'>
                <i class="bi bi-people me-2"></i> Usuarios
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "roles" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("roles")'>
                <i class="bi bi-shield-lock me-2"></i> Roles
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "conjunto")
        {
            <EntityTable TItem="Conjunto"
                         Title="Datos del Conjunto"
                         Headers='new() { "Nombre", "DirecciÃ³n", "Ciudad", "NIT", "TelÃ©fono" }'
                         Items="conjuntoRows"
                         ShowReportButton="true" ReportEntity="conjuntos"
                         OnAddRow='() => AddRow(conjuntoRows)' OnSaveRow='SaveConjunto'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                    <td><input type="text" class="form-control" @bind="row.Direccion" placeholder="DirecciÃ³n" /></td>
                    <td><input type="text" class="form-control" @bind="row.Ciudad" placeholder="Ciudad" /></td>
                    <td><input type="text" class="form-control" @bind="row.Nit" placeholder="NIT" /></td>
                    <td><input type="text" class="form-control" @bind="row.Telefono" placeholder="TelÃ©fono" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "usuarios")
        {
            <EntityTable TItem="Usuario"
                         Title="Listado de Usuarios"
                         Headers='new() { "Nombre", "Email", "Teléfono", "Rol", "Es Propietario", "Apartamento", "Torre" }'
                         Items="usuariosRows"
                         ShowReportButton="true" ReportEntity="usuarios"
                         OnAddRow='() => AddRow(usuariosRows)' OnSaveRow='SaveUsuario'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                    <td><input type="text" class="form-control" @bind="row.Email" placeholder="Email" /></td>
                    <td><input type="text" class="form-control" @bind="row.Telefono" placeholder="Teléfono" /></td>
                    <td>
                        <select class="form-select" @bind="row.RolId">
                            <option value="0">Seleccionar Rol...</option>
                            @foreach (var rol in allRoles)
                            {
                                <option value="@rol.RolId">@rol.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" @bind="row.EsPropietario" />
                        </div>
                    </td>
                    <td>
                        <select class="form-select" value="@row.ApartamentoId" @onchange="@(e => OnApartamentoChanged(row, e.Value?.ToString()))">
                            <option value="">Ninguno</option>
                            @foreach (var a in allApartamentos)
                            {
                                <option value="@((int)a.UnidadId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.TorreId" disabled>
                            <option value="">N/A</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "roles")
        {
            <EntityTable TItem="Rol"
                         Title="Listado de Roles"
                         Headers='new() { "Rol Id", "Nombre" }'
                         Items="rolesRows"
                         ShowReportButton="true" ReportEntity="roles"
                         OnAddRow='() => AddRow(rolesRows)' OnSaveRow='SaveRol'>
                <RowTemplate Context="row">
                    <td><input type="number" class="form-control" @bind="row.RolId" placeholder="Rol Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "conjunto";
    
    private List<Conjunto> conjuntoRows = new();
    private List<Usuario> usuariosRows = new();
    private List<Rol> rolesRows = new();
    private List<Rol> allRoles = new();
    private List<Apartamento> allApartamentos = new();
    private List<Torre> allTorres = new();

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            conjuntoRows = await Http.GetFromJsonAsync<List<Conjunto>>("api/conjuntos") ?? new();
            usuariosRows = await Http.GetFromJsonAsync<List<Usuario>>("api/usuarios") ?? new();
            rolesRows = await Http.GetFromJsonAsync<List<Rol>>("api/roles") ?? new();
            allApartamentos = await Http.GetFromJsonAsync<List<Apartamento>>("api/apartamentos") ?? new();
            allTorres = await Http.GetFromJsonAsync<List<Torre>>("api/torres") ?? new();
            allRoles = rolesRows;

            if (conjuntoRows.Count == 0) conjuntoRows.Add(new Conjunto());
            if (usuariosRows.Count == 0) usuariosRows.Add(new Usuario());
            if (rolesRows.Count == 0) rolesRows.Add(new Rol());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
            // Fallback para desarrollo
            if (conjuntoRows.Count == 0) conjuntoRows.Add(new Conjunto());
            if (usuariosRows.Count == 0) usuariosRows.Add(new Usuario());
            if (rolesRows.Count == 0) rolesRows.Add(new Rol());
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow<T>(List<T> target) where T : new()
    {
        target.Add(new T());
    }

    private void OnApartamentoChanged(Usuario row, string? value)
    {
        if (string.IsNullOrEmpty(value) || !int.TryParse(value, out int aptoId))
        {
            row.ApartamentoId = null;
            row.TorreId = null;
        }
        else
        {
            row.ApartamentoId = aptoId;
            var apto = allApartamentos.FirstOrDefault(a => a.UnidadId == aptoId);
            if (apto != null)
            {
                row.TorreId = apto.TorreId;
            }
        }
    }

    private async Task SaveConjunto(Conjunto conjunto)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/conjuntos", conjunto);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Conjunto>();
                if (saved != null) conjunto.ConjuntoId = saved.ConjuntoId;
                await JS.InvokeVoidAsync("alert", "Conjunto guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Conjunto: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar el Conjunto. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveUsuario(Usuario usuario)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/usuarios", usuario);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Usuario>();
                if (saved != null) usuario.UsuarioId = saved.UsuarioId;
                await JS.InvokeVoidAsync("alert", "Usuario guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Usuario: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar el Usuario. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveRol(Rol rol)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/roles", rol);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Rol>();
                if (saved != null) rol.RolId = saved.RolId;
                await JS.InvokeVoidAsync("alert", "Rol guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Rol: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar el Rol. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }
}
