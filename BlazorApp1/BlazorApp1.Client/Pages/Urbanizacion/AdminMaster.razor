@page "/urbanizacion/admin"
@rendermode InteractiveWebAssembly
@attribute [Authorize(Roles = "3")]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Administración - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Panel Administrativo</h1>
            <p class="text-muted mb-0">Gestión de la propiedad, personal y niveles de acceso.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 p-2 rounded-3 shadow-sm d-inline-flex border" style="background-color: var(--card-bg); border-color: rgba(255,255,255,0.05) !important;">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "conjunto" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("conjunto")'>
                <i class="bi bi-houses me-2"></i> Conjunto
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "usuarios" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("usuarios")'>
                <i class="bi bi-people me-2"></i> Usuarios
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "roles" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("roles")'>
                <i class="bi bi-shield-lock me-2"></i> Roles
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "registro_usuario" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("registro_usuario")'>
                <i class="bi bi-person-plus me-2"></i> Registrar Usuario
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "modificar_usuario" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("modificar_usuario")'>
                <i class="bi bi-pencil-square me-2"></i> Modificar Usuario
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "conjunto")
        {
            <EntityTable TItem="Conjunto"
                         Title="Datos del Conjunto"
                         Headers='new() { "Nombre", "DirecciÃ³n", "Ciudad", "NIT", "TelÃ©fono" }'
                         Items="conjuntoRows"
                         ShowReportButton="true" ReportEntity="conjuntos"
                         OnAddRow='() => AddRow(conjuntoRows)' OnSaveRow='SaveConjunto'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                    <td><input type="text" class="form-control" @bind="row.Direccion" placeholder="DirecciÃ³n" /></td>
                    <td><input type="text" class="form-control" @bind="row.Ciudad" placeholder="Ciudad" /></td>
                    <td><input type="text" class="form-control" @bind="row.Nit" placeholder="NIT" /></td>
                    <td><input type="text" class="form-control" @bind="row.Telefono" placeholder="TelÃ©fono" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "usuarios")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex gap-3 align-items-end">
                    <div style="width: 250px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Rol</label>
                        <select class="form-select form-select-sm" @bind="filtroRolId">
                            <option value="0">Todos los Roles</option>
                            @foreach (var rol in allRoles)
                            {
                                <option value="@rol.RolId">@rol.Nombre</option>
                            }
                        </select>
                    </div>
                    <div style="width: 250px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Propietario</label>
                        <select class="form-select form-select-sm" @bind="filtroPropietario">
                            <option value="todos">Todos</option>
                            <option value="si">Solo Propietarios</option>
                            <option value="no">No Propietarios</option>
                        </select>
                    </div>
                </div>
            </div>

            <EntityTable TItem="Usuario"
                         Title="Listado de Usuarios"
                         Headers='new() { "Nombre", "Email", "Teléfono", "Es Propietario", "Apartamento", "Torre", "Unidad" }'
                         Items="FilteredUsuariosRows"
                         ShowReportButton="true" ReportEntity="usuarios"
                         ReadOnly="true">
                <RowTemplate Context="row">
                    @{
                        var apto = allApartamentos.FirstOrDefault(a => a.ApartamentoId == row.ApartamentoId);
                        var torre = allTorres.FirstOrDefault(t => t.TorreId == (apto != null ? apto.TorreId : row.TorreId));
                        var conjunto = conjuntoRows.FirstOrDefault(c => c.ConjuntoId == (torre != null ? torre.ConjuntoId : 0));
                    }
                    <td class="fw-medium">@row.Nombre</td>
                    <td>@row.Email</td>
                    <td>@row.Telefono</td>
                    <td>
                        <span class="badge @(row.EsPropietario == true ? "bg-success" : "bg-secondary")">
                            @(row.EsPropietario == true ? "Sí" : "No")
                        </span>
                    </td>
                    <td>@(apto != null ? $"{apto.Numero} - {apto.Tipo}" : "N/A")</td>
                    <td>@(torre != null ? torre.Nombre : "N/A")</td>
                    <td>@(conjunto != null ? conjunto.Nombre : "N/A")</td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "modificar_usuario")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex flex-wrap gap-3 align-items-end">
                    <div style="width: 250px;">
                        <label class="form-label fw-bold small text-muted mb-1">Buscar</label>
                        <input type="text" class="form-control form-control-sm" @bind="busquedaMod" @bind:event="oninput" placeholder="Nombre, Documento, Email..." />
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Rol</label>
                        <select class="form-select form-select-sm" @bind="filtroRolIdMod">
                            <option value="0">Todos los Roles</option>
                            @foreach (var rol in allRoles)
                            {
                                <option value="@rol.RolId">@rol.Nombre</option>
                            }
                        </select>
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Propietario</label>
                        <select class="form-select form-select-sm" @bind="filtroPropietarioMod">
                            <option value="todos">Todos</option>
                            <option value="si">Solo Propietarios</option>
                            <option value="no">No Propietarios</option>
                        </select>
                    </div>
                </div>
            </div>

            <EntityTable TItem="Usuario"
                         Title="Modificar Usuarios"
                         Headers='new() { "Nombre", "Documento", "Email", "Teléfono", "Clave", "Rol", "Es Propietario", "Apartamento", "Torre", "Conjunto" }'
                         Items="FilteredModificarUsuariosRows"
                         ShowReportButton="false"
                         OnAddRow='() => AddRow(usuariosRows)' OnSaveRow='SaveUsuario'>
                <RowTemplate Context="row">
                    @{
                        var t = allTorres.FirstOrDefault(x => x.TorreId == row.TorreId);
                        var c = t != null ? conjuntoRows.FirstOrDefault(x => x.ConjuntoId == t.ConjuntoId) : null;
                    }
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                    <td><input type="text" class="form-control" @bind="row.Documento" placeholder="Documento" /></td>
                    <td><input type="email" class="form-control" @bind="row.Email" placeholder="Email" /></td>
                    <td><input type="text" class="form-control" @bind="row.Telefono" placeholder="Teléfono" /></td>
                    <td><input type="text" class="form-control" @bind="row.Clave" placeholder="Clave" /></td>
                    <td>
                        <select class="form-select" @bind="row.RolId">
                            <option value="0">Seleccionar Rol...</option>
                            @foreach (var rol in allRoles)
                            {
                                <option value="@rol.RolId">@rol.Nombre</option>
                            }
                        </select>
                    </td>
                    <td class="text-center">
                        <div class="form-check form-switch mt-1 d-inline-block">
                            <input class="form-check-input" type="checkbox" @bind="row.EsPropietario" />
                        </div>
                    </td>
                    <td>
                        <select class="form-select" value="@row.ApartamentoId" @onchange="@(e => OnApartamentoChanged(row, e.Value?.ToString()))">
                            <option value="">Ninguno</option>
                            @foreach (var a in allApartamentos)
                            {
                                <option value="@((int)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <input type="text" class="form-control" value="@(t?.Nombre ?? "N/A")" readonly disabled />
                    </td>
                    <td>
                        <input type="text" class="form-control" value="@(c?.Nombre ?? "N/A")" readonly disabled />
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "roles")
        {
            <EntityTable TItem="Rol"
                         Title="Listado de Roles"
                         Headers='new() { "Rol Id", "Nombre" }'
                         Items="rolesRows"
                         ShowReportButton="true" ReportEntity="roles"
                         OnAddRow='() => AddRow(rolesRows)' OnSaveRow='SaveRol'>
                <RowTemplate Context="row">
                    <td><input type="number" class="form-control" @bind="row.RolId" placeholder="Rol Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "registro_usuario")
        {
            <div class="card mb-5 border-0 shadow-sm animate-fade-in">
                <div class="card-header py-3" style="background-color: var(--card-bg) !important;">
                    <h5 class="fw-bold mb-0 text-white">Registro de Nuevo Usuario</h5>
                </div>
                <div class="card-body p-4">
                    <form @onsubmit="RegisterUser" @onsubmit:preventDefault="true">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Nombre Completo <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" @bind="newUser.Nombre" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Documento <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" value="@newUser.Documento" @onchange="OnDocumentoChanged" required />
                                <small class="text-muted">La clave se asignará automáticamente igual al documento.</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Email <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" @bind="newUser.Email" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Teléfono</label>
                                <input type="text" class="form-control" @bind="newUser.Telefono" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Rol <span class="text-danger">*</span></label>
                                <select class="form-select" @bind="newUser.RolId" required>
                                    <option value="0">Seleccionar Rol...</option>
                                    @foreach (var rol in allRoles)
                                    {
                                        <option value="@rol.RolId">@rol.Nombre</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input class="form-check-input" type="checkbox" id="esPropietarioSwitch" @bind="newUser.EsPropietario" />
                                    <label class="form-check-label fw-bold" for="esPropietarioSwitch">Es Propietario</label>
                                </div>
                            </div>

                            <h6 class="mt-4 mb-2 fw-bold text-primary border-bottom pb-2">Información de Residencia (Opcional)</h6>

                            <div class="col-md-4">
                                <label class="form-label fw-bold">Apartamento</label>
                                <select class="form-select" value="@newUser.ApartamentoId" @onchange="OnNewUserApartamentoChanged">
                                    <option value="">Seleccionar Apartamento...</option>
                                    @foreach (var a in allApartamentos)
                                    {
                                        <option value="@((int)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Torre</label>
                                <input type="text" class="form-control bg-light" value="@selectedTorreName" readonly />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Unidad / Conjunto</label>
                                <input type="text" class="form-control bg-light" value="@selectedConjuntoName" readonly />
                            </div>

                            <div class="col-12 mt-4 text-end">
                                <button type="button" class="btn btn-secondary me-2" @onclick="ResetNewUserForm">Limpiar</button>
                                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-person-check me-2"></i> Registrar Usuario</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "conjunto";
    
    private List<Conjunto> conjuntoRows = new();
    private List<Usuario> usuariosRows = new();
    private List<Rol> rolesRows = new();
    private List<Rol> allRoles = new();
    private List<Apartamento> allApartamentos = new();
    private List<Torre> allTorres = new();

    private Usuario newUser = new Usuario();
    private string selectedTorreName = "N/A";
    private string selectedConjuntoName = "N/A";

    // Filtros de tabla
    private int filtroRolId = 0;
    private string filtroPropietario = "todos";

    // Filtros modificar usuarios
    private int filtroRolIdMod = 0;
    private string filtroPropietarioMod = "todos";
    private string busquedaMod = "";

    private List<Usuario> FilteredModificarUsuariosRows
    {
        get
        {
            var query = usuariosRows.AsEnumerable();
            if (filtroRolIdMod != 0)
            {
                query = query.Where(u => u.UsuarioId == 0 || u.RolId == filtroRolIdMod);
            }
            if (filtroPropietarioMod == "si")
            {
                query = query.Where(u => u.UsuarioId == 0 || u.EsPropietario == true);
            }
            else if (filtroPropietarioMod == "no")
            {
                query = query.Where(u => u.UsuarioId == 0 || u.EsPropietario != true);
            }
            if (!string.IsNullOrWhiteSpace(busquedaMod))
            {
                var lowerSearch = busquedaMod.ToLower();
                query = query.Where(u => u.UsuarioId == 0 || 
                    (u.Nombre != null && u.Nombre.ToLower().Contains(lowerSearch)) ||
                    (u.Documento != null && u.Documento.ToLower().Contains(lowerSearch)) ||
                    (u.Email != null && u.Email.ToLower().Contains(lowerSearch)));
            }
            return query.ToList();
        }
    }

    private List<Usuario> FilteredUsuariosRows
    {
        get
        {
            var query = usuariosRows.AsEnumerable();
            if (filtroRolId != 0)
            {
                query = query.Where(u => u.RolId == filtroRolId);
            }
            if (filtroPropietario == "si")
            {
                query = query.Where(u => u.EsPropietario == true);
            }
            else if (filtroPropietario == "no")
            {
                query = query.Where(u => u.EsPropietario != true);
            }
            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            conjuntoRows = await Http.GetFromJsonAsync<List<Conjunto>>("api/conjuntos") ?? new();
            usuariosRows = await Http.GetFromJsonAsync<List<Usuario>>("api/usuarios") ?? new();
            rolesRows = await Http.GetFromJsonAsync<List<Rol>>("api/roles") ?? new();
            allApartamentos = await Http.GetFromJsonAsync<List<Apartamento>>("api/apartamentos") ?? new();
            allTorres = await Http.GetFromJsonAsync<List<Torre>>("api/torres") ?? new();
            allRoles = rolesRows;

            if (conjuntoRows.Count == 0) conjuntoRows.Add(new Conjunto());
            if (usuariosRows.Count == 0) usuariosRows.Add(new Usuario());
            if (rolesRows.Count == 0) rolesRows.Add(new Rol());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
            // Fallback para desarrollo
            if (conjuntoRows.Count == 0) conjuntoRows.Add(new Conjunto());
            if (usuariosRows.Count == 0) usuariosRows.Add(new Usuario());
            if (rolesRows.Count == 0) rolesRows.Add(new Rol());
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow<T>(List<T> target) where T : new()
    {
        target.Add(new T());
    }

    private void OnApartamentoChanged(Usuario row, string? value)
    {
        if (string.IsNullOrEmpty(value) || !int.TryParse(value, out int aptoId))
        {
            row.ApartamentoId = null;
            row.TorreId = null;
        }
        else
        {
            row.ApartamentoId = aptoId;
            var apto = allApartamentos.FirstOrDefault(a => a.ApartamentoId == aptoId);
            if (apto != null)
            {
                row.TorreId = apto.TorreId;
            }
        }
    }

    private async Task SaveConjunto(Conjunto conjunto)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/conjuntos", conjunto);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Conjunto>();
                if (saved != null) conjunto.ConjuntoId = saved.ConjuntoId;
                await JS.InvokeVoidAsync("alert", "Conjunto guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Conjunto: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar el Conjunto. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveUsuario(Usuario usuario)
    {
        if (usuariosRows.Any(u => u.UsuarioId != usuario.UsuarioId && !string.IsNullOrEmpty(u.Documento) && u.Documento.Equals(usuario.Documento, StringComparison.OrdinalIgnoreCase)))
        {
            await JS.InvokeVoidAsync("alert", "Ya existe un usuario con este documento.");
            return;
        }

        if (usuariosRows.Any(u => u.UsuarioId != usuario.UsuarioId && !string.IsNullOrEmpty(u.Email) && u.Email.Equals(usuario.Email, StringComparison.OrdinalIgnoreCase)))
        {
            await JS.InvokeVoidAsync("alert", "Ya existe un usuario registrado con este email.");
            return;
        }

        if (usuario.EsPropietario == true && usuario.ApartamentoId.HasValue)
        {
            if (usuariosRows.Any(u => u.UsuarioId != usuario.UsuarioId && u.ApartamentoId == usuario.ApartamentoId && u.EsPropietario == true))
            {
                await JS.InvokeVoidAsync("alert", "Ya existe un propietario registrado para este apartamento. Solo puede haber un propietario por apartamento.");
                return;
            }
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/usuarios", usuario);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Usuario>();
                if (saved != null) usuario.UsuarioId = saved.UsuarioId;
                await JS.InvokeVoidAsync("alert", "Usuario guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Usuario: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar el Usuario. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveRol(Rol rol)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/roles", rol);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Rol>();
                if (saved != null) rol.RolId = saved.RolId;
                await JS.InvokeVoidAsync("alert", "Rol guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Rol: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar el Rol. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private void OnDocumentoChanged(ChangeEventArgs e)
    {
        var val = e.Value?.ToString() ?? "";
        newUser.Documento = val;
        newUser.Clave = val;
    }

    private void OnNewUserApartamentoChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int aptoId))
        {
            newUser.ApartamentoId = aptoId;
            var apto = allApartamentos.FirstOrDefault(a => a.ApartamentoId == aptoId);
            if (apto != null)
            {
                newUser.TorreId = apto.TorreId;
                var torre = allTorres.FirstOrDefault(t => t.TorreId == apto.TorreId);
                selectedTorreName = torre != null ? torre.Nombre : "N/A";

                if (torre != null)
                {
                    var conjunto = conjuntoRows.FirstOrDefault(c => c.ConjuntoId == torre.ConjuntoId);
                    selectedConjuntoName = conjunto != null ? conjunto.Nombre : "N/A";
                }
                else
                {
                     selectedConjuntoName = "N/A";
                }
            }
        }
        else
        {
            newUser.ApartamentoId = null;
            newUser.TorreId = null;
            selectedTorreName = "N/A";
            selectedConjuntoName = "N/A";
        }
    }

    private void ResetNewUserForm()
    {
        newUser = new Usuario();
        selectedTorreName = "N/A";
        selectedConjuntoName = "N/A";
    }

    private async Task RegisterUser()
    {
        if (string.IsNullOrWhiteSpace(newUser.Documento) || string.IsNullOrWhiteSpace(newUser.Email) || string.IsNullOrWhiteSpace(newUser.Nombre) || newUser.RolId == 0)
        {
            await JS.InvokeVoidAsync("alert", "Debe completar los campos obligatorios (Nombre, Documento, Email, Rol).");
            return;
        }

        if (usuariosRows.Any(u => !string.IsNullOrEmpty(u.Documento) && u.Documento.Equals(newUser.Documento, StringComparison.OrdinalIgnoreCase)))
        {
            await JS.InvokeVoidAsync("alert", "Ya existe un usuario con este documento.");
            return;
        }

        if (usuariosRows.Any(u => !string.IsNullOrEmpty(u.Email) && u.Email.Equals(newUser.Email, StringComparison.OrdinalIgnoreCase)))
        {
            await JS.InvokeVoidAsync("alert", "Ya existe un usuario registrado con este email.");
            return;
        }

        if (newUser.EsPropietario == true && newUser.ApartamentoId.HasValue)
        {
            if (usuariosRows.Any(u => u.ApartamentoId == newUser.ApartamentoId && u.EsPropietario == true))
            {
                await JS.InvokeVoidAsync("alert", "Ya existe un propietario registrado para este apartamento. Solo puede haber un propietario por apartamento.");
                return;
            }
        }

        newUser.Clave = newUser.Documento;

        try
        {
            var response = await Http.PostAsJsonAsync("api/usuarios", newUser);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Usuario>();
                if (saved != null) 
                {
                    if (usuariosRows.Count == 1 && usuariosRows[0].UsuarioId == 0)
                    {
                        usuariosRows.Clear();
                    }
                    usuariosRows.Add(saved);
                }
                await JS.InvokeVoidAsync("alert", "Usuario registrado correctamente!");
                ResetNewUserForm();
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Error al registrar usuario:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Excepción del cliente: {e.Message}");
        }
    }
}
