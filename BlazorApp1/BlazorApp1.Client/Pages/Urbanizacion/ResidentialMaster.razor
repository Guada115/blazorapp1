@page "/urbanizacion/residencial"
@rendermode InteractiveWebAssembly
@inject HttpClient Http

<PageTitle>Gestión Residencial - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Gestión Residencial</h1>
            <p class="text-muted mb-0">Administración de la estructura física y vinculación de residentes.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 bg-white p-2 rounded-3 shadow-sm d-inline-flex border">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "torres" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("torres")'>
                <i class="bi bi-layers me-2"></i> Torres
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "apartamentos" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("apartamentos")'>
                <i class="bi bi-building me-2"></i> Apartamentos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "residentes" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("residentes")'>
                <i class="bi bi-person-badge me-2"></i> Residentes
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "torres")
        {
            <EntityTable TItem="Torre"
                         Title="Listado de Torres"
                         Headers='new() { "Conjunto", "Nombre Torre" }'
                         Items="torreRows"
                         OnAddRow='() => AddRow(torreRows)'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.ConjuntoId">
                            <option value="0">Seleccionar Conjunto...</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@c.ConjuntoId">@c.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre Torre" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "apartamentos")
        {
            <EntityTable TItem="Apartamento"
                         Title="Listado de Apartamentos"
                         Headers='new() { "Número", "Torre", "Tipo", "Área" }'
                         Items="apartamentoRows"
                         OnAddRow='() => AddRow(apartamentoRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Numero" placeholder="Número" /></td>
                    <td>
                        <select class="form-select" @bind="row.TorreId">
                            <option value="0">Seleccionar Torre...</option>
                            @foreach (var t in torreRows)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="text" class="form-control" @bind="row.Tipo" placeholder="Tipo" /></td>
                    <td><input type="number" class="form-control" @bind="row.Area" placeholder="Área" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "residentes")
        {
            <EntityTable TItem="ResidenteUnidad"
                         Title="Listado de Residentes"
                         Headers='new() { "Usuario", "Unidad", "Es Propietario" }'
                         Items="residenteRows"
                         OnAddRow='() => AddRow(residenteRows)'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.UsuarioId">
                            <option value="0">Seleccionar Usuario...</option>
                            @foreach (var u in allUsuarios)
                            {
                                <option value="@u.UsuarioId">@u.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.UnidadId">
                            <option value="0">Seleccionar Unidad...</option>
                            @foreach (var a in apartamentoRows)
                            {
                                <option value="@a.UnidadId">@a.Numero (@a.Tipo)</option>
                            }
                        </select>
                    </td>
                    <td>
                        <div class="form-check form-switch mt-1">
                            <input class="form-check-input" type="checkbox" @bind="row.EsPropietario" />
                        </div>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "torres";
    
    private List<Torre> torreRows = new();
    private List<Apartamento> apartamentoRows = new();
    private List<ResidenteUnidad> residenteRows = new();
    private List<Conjunto> allConjuntos = new();
    private List<Usuario> allUsuarios = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            torreRows = await Http.GetFromJsonAsync<List<Torre>>("api/torres") ?? new();
            apartamentoRows = await Http.GetFromJsonAsync<List<Apartamento>>("api/apartamentos") ?? new();
            residenteRows = await Http.GetFromJsonAsync<List<ResidenteUnidad>>("api/residentesunidades") ?? new();
            allConjuntos = await Http.GetFromJsonAsync<List<Conjunto>>("api/conjuntos") ?? new();
            allUsuarios = await Http.GetFromJsonAsync<List<Usuario>>("api/usuarios") ?? new();
            
            if (torreRows.Count == 0) torreRows.Add(new Torre());
            if (apartamentoRows.Count == 0) apartamentoRows.Add(new Apartamento());
            if (residenteRows.Count == 0) residenteRows.Add(new ResidenteUnidad());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
            if (torreRows.Count == 0) torreRows.Add(new Torre());
            if (apartamentoRows.Count == 0) apartamentoRows.Add(new Apartamento());
            if (residenteRows.Count == 0) residenteRows.Add(new ResidenteUnidad());
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow<T>(List<T> target) where T : new()
    {
        target.Add(new T());
    }
}
