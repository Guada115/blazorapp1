@page "/urbanizacion/residencial"
@rendermode InteractiveWebAssembly
@attribute [Authorize(Roles = "3")]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Gestión Residencial - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Gestión Residencial</h1>
            <p class="text-muted mb-0">Administración de la estructura fí­sica torres y apartamentos.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 p-2 rounded-3 shadow-sm d-inline-flex border" style="background-color: var(--card-bg); border-color: rgba(255,255,255,0.05) !important;">      
        <li class="nav-item">
            <button class="nav-link @(activeTab == "torres" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("torres")'>
                <i class="bi bi-layers me-2"></i> Torres
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "apartamentos" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("apartamentos")'>
                <i class="bi bi-building me-2"></i> Apartamentos
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "torres")
        {
            <EntityTable TItem="Torre"
                         Title="Listado de Torres"
                         Headers='new() { "Conjunto", "Nombre Torre" }'
                         Items="torreRows"
                         ShowReportButton="true" ReportEntity="torres"
                         OnAddRow='() => AddRow(torreRows)' OnSaveRow='SaveTorre'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.ConjuntoId">
                            <option value="0">Seleccionar Conjunto...</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@c.ConjuntoId">@c.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="text" class="form-control" @bind="row.Nombre" placeholder="Nombre Torre" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "apartamentos")
        {
            <EntityTable TItem="Apartamento"
                         Title="Registro de Apartamentos"
                         Headers='new() { "NÃºmero", "Torre", "Tipo", "Conjunto" }'
                         Items="apartamentoRows"
                         ShowReportButton="true" ReportEntity="apartamentos"
                         OnAddRow='() => AddRow(apartamentoRows)' OnSaveRow='SaveApartamento'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Numero" placeholder="NÃºmero" /></td>
                    <td>
                        <select class="form-select" value="@row.TorreId" @onchange="@(e => OnTorreChanged(row, e.Value?.ToString()))">
                            <option value="0">Seleccionar Torre...</option>
                            @foreach (var t in torreRows)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.Tipo">
                            <option value="">Seleccionar Tipo...</option>
                            <option value="apartaestudio">Apartaestudio</option>
                            <option value="familiar">Familiar</option>
                            <option value="duplex">DÃºplex</option>
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.ConjuntoId" disabled>
                            <option value="">Seleccionar Conjunto...</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@((int)c.ConjuntoId)">@c.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }

    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }

    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "torres";

    private List<Torre> torreRows = new();
    private List<Apartamento> apartamentoRows = new();
    private List<Conjunto> allConjuntos = new();

    protected override async Task OnInitializedAsync()
    {
        try { torreRows = await Http.GetFromJsonAsync<List<Torre>>("api/torres") ?? new(); } catch (Exception ex) { Console.WriteLine("Torres err: " + ex.Message); }
        try { apartamentoRows = await Http.GetFromJsonAsync<List<Apartamento>>("api/apartamentos") ?? new(); } catch (Exception ex) { Console.WriteLine("Aptos err: " + ex.Message); }
        try { allConjuntos = await Http.GetFromJsonAsync<List<Conjunto>>("api/conjuntos") ?? new(); } catch (Exception ex) { Console.WriteLine("Conjuntos err: " + ex.Message); }

        if (torreRows.Count == 0) torreRows.Add(new Torre());
        if (apartamentoRows.Count == 0) apartamentoRows.Add(new Apartamento());
    }

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow<T>(List<T> target) where T : new()
    {
        target.Add(new T());
    }

    private void OnTorreChanged(Apartamento row, string? value)
    {
        if (int.TryParse(value, out int torreId))
        {
            row.TorreId = torreId;
            var torre = torreRows.FirstOrDefault(t => t.TorreId == torreId);
            if (torre != null)
            {
                row.ConjuntoId = torre.ConjuntoId;
            }
        }
        else
        {
            row.TorreId = 0;
            row.ConjuntoId = null;
        }
    }

    private async Task SaveTorre(Torre torre)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/torres", torre);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Torre>();
                if (saved != null) torre.TorreId = saved.TorreId;
                await JS.InvokeVoidAsync("alert", "Torre guardada correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Torre: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar la Torre. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveApartamento(Apartamento apartamento)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/apartamentos", apartamento);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Apartamento>();
                if (saved != null) apartamento.ApartamentoId = saved.ApartamentoId;
                await JS.InvokeVoidAsync("alert", "Apartamento guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Apartamento: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar Apartamento. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }
}
