@page "/urbanizacion/residencial"
@rendermode InteractiveWebAssembly

<PageTitle>Gestión Residencial - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Gestión Residencial</h1>
            <p class="text-muted mb-0">Administración de la estructura física y vinculación de residentes.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 bg-white p-2 rounded-3 shadow-sm d-inline-flex border">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "torres" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("torres")'>
                <i class="bi bi-layers me-2"></i> Torres
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "apartamentos" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("apartamentos")'>
                <i class="bi bi-building me-2"></i> Apartamentos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "residentes" ? "active" : "") fw-semibold px-4" @onclick='() => SetTab("residentes")'>
                <i class="bi bi-person-badge me-2"></i> Residentes
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "torres")
        {
            <EntityTable TItem="TableRow"
                         Title="Listado de Torres"
                         Headers='new() { "Torre Id", "Nombre Torre" }'
                         Items="torreRows"
                         OnAddRow='() => AddRow(torreRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Torre Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="Nombre Torre" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "apartamentos")
        {
            <EntityTable TItem="TableRow"
                         Title="Listado de Apartamentos"
                         Headers='new() { "Unidad", "Torre Id", "Tipo", "Estado", "Propietario" }'
                         Items="apartamentoRows"
                         OnAddRow='() => AddRow(apartamentoRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Unidad" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="Torre Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato3" placeholder="Tipo" /></td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <StatusBadge Status="@(string.IsNullOrEmpty(row.Dato4) ? "Disponible" : row.Dato4)" 
                                         Type='@(row.Dato4 == "Ocupado" ? "danger" : "success")' />
                            <input type="text" class="form-control form-control-sm w-50" @bind="row.Dato4" placeholder="Editar Estado" />
                        </div>
                    </td>
                    <td><input type="text" class="form-control" @bind="row.Dato5" placeholder="Propietario" /></td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "residentes")
        {
            <EntityTable TItem="TableRow"
                         Title="Listado de Residentes"
                         Headers='new() { "Residente Id", "Torre Id", "Unidad" }'
                         Items="residenteRows"
                         OnAddRow='() => AddRow(residenteRows)'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Dato1" placeholder="Residente Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato2" placeholder="Torre Id" /></td>
                    <td><input type="text" class="form-control" @bind="row.Dato3" placeholder="Unidad" /></td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "torres";
    
    private List<TableRow> torreRows = new() { new TableRow() };
    private List<TableRow> apartamentoRows = new() { new TableRow() };
    private List<TableRow> residenteRows = new() { new TableRow() };

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow(List<TableRow> target)
    {
        target.Add(new TableRow());
    }
}
