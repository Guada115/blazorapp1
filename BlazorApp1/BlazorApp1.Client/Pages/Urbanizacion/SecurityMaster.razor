@page "/urbanizacion/seguridad"
@rendermode InteractiveWebAssembly
@attribute [Authorize(Roles = "1,3")]
@inject HttpClient Http
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Seguridad & Acceso - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Seguridad & Acceso</h1>
            <p class="text-muted mb-0">Control de entradas, bit�cora de vigilancia y gesti�n de parqueaderos.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 p-2 rounded-3 shadow-sm d-inline-flex border overflow-auto flex-nowrap w-100" style="background-color: var(--card-bg); border-color: rgba(255,255,255,0.05) !important;">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "ingresos" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("ingresos")'>
                <i class="bi bi-door-open me-2"></i> Ingresos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "bitacora" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("bitacora")'>
                <i class="bi bi-journal-text me-2"></i> Bit�cora
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "parqueadero" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("parqueadero")'>
                <i class="bi bi-p-square me-2"></i> Parqueaderos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "visitantes" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("visitantes")'>
                <i class="bi bi-p-square-fill me-2"></i> Visitantes
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "cuartoutil" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("cuartoutil")'>
                <i class="bi bi-door-closed me-2"></i> Cuarto Útil
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "ingresos")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex flex-wrap gap-3 align-items-end">
                    <div style="width: 160px;">
                        <label class="form-label fw-bold small text-muted mb-1">Tipo</label>
                        <select class="form-select form-select-sm" @bind="filtroTipoIng">
                            <option value="">Todos</option>
                            <option value="visita">Visita</option>
                            <option value="domicilio">Domicilio</option>
                            <option value="proveedor">Proveedor</option>
                            <option value="transporte">Transporte</option>
                            <option value="correo">Correo</option>
                            <option value="reunión">Reunión</option>
                        </select>
                    </div>
                    <div style="width: 180px;">
                        <label class="form-label fw-bold small text-muted mb-1">Fecha</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtroFechaIng" />
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Apartamento</label>
                        <select class="form-select form-select-sm" @bind="filtroAptoIng">
                            <option value="0">Todos</option>
                            @foreach (var a in allUnidades) { <option value="@a.ApartamentoId">@a.Numero</option> }
                        </select>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => { filtroTipoIng=string.Empty; filtroFechaIng=null; filtroAptoIng=0; }">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </button>
                </div>
            </div>
            <EntityTable TItem="Ingreso"
                         Title="Registro de Ingresos"
                         Headers='new() { "Tipo", "Nombre", "Documento", "Ingreso", "Salida", "Apartamento", "Torre", "Conjunto", "Observaciones" }'
                         Items="FilteredIngresoRows"
                         ShowReportButton="true" ReportEntity="ingresos" RequiresDateRange="true"
                         OnAddRow='() => AddRow(ingresoRows)' OnSaveRow='SaveIngreso'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.Tipo">
                            <option value="">Seleccionar...</option>
                            <option value="visita">Visita</option>
                            <option value="domicilio">Domicilio</option>
                            <option value="proveedor">Proveedor</option>
                            <option value="transporte">Transporte</option>
                            <option value="correo">Correo</option>
                            <option value="reunión">Reunión</option>
                        </select>
                    </td>
                    <td><input type="text" class="form-control" @bind="row.NombrePersona" placeholder="Nombre" /></td>
                    <td><input type="text" class="form-control" @bind="row.Documento" placeholder="Doc" /></td>
                    <td><input type="datetime-local" class="form-control" @bind="row.FechaHoraIngreso" /></td>
                    <td><input type="datetime-local" class="form-control" @bind="row.FechaHoraSalida" /></td>
                    <td>
                        <select class="form-select" value="@row.ApartamentoId" @onchange="@(e => OnApartamentoChanged(row, e.Value?.ToString()))">
                            <option value="">Seleccionar...</option>
                            @foreach (var a in allUnidades)
                            {
                                <option value="@((int)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.TorreId" disabled>
                            <option value="0">N/A</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.ConjuntoId" disabled>
                            <option value="">N/A</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@c.ConjuntoId">@c.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <textarea class="form-control" rows="1" @bind="row.Observaciones" placeholder="Observaciones..."
                                  style="resize:none; overflow:hidden; min-height: 38px;"
                                  oninput="this.style.height = 'auto'; this.style.height = (this.scrollHeight) + 'px';"></textarea>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "bitacora")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex flex-wrap gap-3 align-items-end">
                    <div style="width: 250px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Vigilante</label>
                        <select class="form-select form-select-sm" @bind="filtroVigilanteBit">
                            <option value="0">Todos los vigilantes</option>
                            @foreach (var v in allVigilantes)
                            {
                                <option value="@v.UsuarioId">@v.Nombre</option>
                            }
                        </select>
                    </div>
                    <div style="width: 180px;">
                        <label class="form-label fw-bold small text-muted mb-1">Desde</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtroFechaInicioBit" />
                    </div>
                    <div style="width: 180px;">
                        <label class="form-label fw-bold small text-muted mb-1">Hasta</label>
                        <input type="date" class="form-control form-control-sm" @bind="filtroFechaFinBit" />
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => { filtroVigilanteBit = 0; filtroFechaInicioBit = null; filtroFechaFinBit = null; }">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </button>
                </div>
            </div>
            <EntityTable TItem="BitacoraVigilancia"
                         Title="Registros de Vigilancia (Bit�cora)"
                         Headers='new() { "Vigilante", "Fecha Hora", "Observaci�n" }'
                         Items="FilteredBitacoraRows"
                         ShowReportButton="true" ReportEntity="bitacora" RequiresDateRange="true"
                         OnAddRow='() => AddRow(bitacoraRows)' OnSaveRow='SaveBitacora'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.VigilanteId" disabled>
                            <option value="0">Seleccionar Vigilante...</option>
                            @foreach (var v in allVigilantes)
                            {
                                <option value="@v.UsuarioId">@v.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="datetime-local" class="form-control" @bind="row.FechaHora" disabled /></td>
                    <td>
                        <textarea class="form-control" rows="1" @bind="row.Observacion" disabled="@(row.BitacoraId != 0)" placeholder="Observaci�n..."
                                  style="resize:none; overflow:hidden; min-height: 38px;"
                                  oninput="this.style.height = 'auto'; this.style.height = (this.scrollHeight) + 'px';"></textarea>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "parqueadero")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex flex-wrap gap-3 align-items-end">
                    <div style="width: 150px;">
                        <label class="form-label fw-bold small text-muted mb-1">Tipo</label>
                        <select class="form-select form-select-sm" @bind="filtroTipoPar">
                            <option value="">Todos</option>
                            <option value="carro">Carro</option>
                            <option value="moto">Moto</option>
                            <option value="movilidad reducida">Movilidad Reducida</option>
                        </select>
                    </div>
                    <div style="width: 150px;">
                        <label class="form-label fw-bold small text-muted mb-1">Torre</label>
                        <select class="form-select form-select-sm" @bind="filtroTorrePar">
                            <option value="0">Todas</option>
                            @foreach (var t in allTorres) { <option value="@t.TorreId">@t.Nombre</option> }
                        </select>
                    </div>
                    <div style="width: 150px;">
                        <label class="form-label fw-bold small text-muted mb-1">Conjunto</label>
                        <select class="form-select form-select-sm" @bind="filtroConjuntoPar">
                            <option value="0">Todos</option>
                            @foreach (var c in allConjuntos) { <option value="@c.ConjuntoId">@c.Nombre</option> }
                        </select>
                    </div>
                    <div style="width: 150px;">
                        <label class="form-label fw-bold small text-muted mb-1">Apartamento</label>
                        <select class="form-select form-select-sm" @bind="filtroAptoPar">
                            <option value="0">Todos</option>
                            @foreach (var a in allUnidades) { <option value="@a.ApartamentoId">@a.Numero</option> }
                        </select>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => { filtroTipoPar=string.Empty; filtroTorrePar=0; filtroConjuntoPar=0; filtroAptoPar=0; }">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </button>
                </div>
            </div>
            <EntityTable TItem="Parqueadero"
                         Title="Espacios de Parqueo"
                         Headers='new() { "Tipo", "Apartamento", "Torre", "Conjunto" }'
                         Items="FilteredParqueaderoRows"
                         ShowReportButton="true" ReportEntity="parqueaderos"
                         OnAddRow='() => AddRow(parqueaderoRows)' OnSaveRow='SaveParqueadero'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.Tipo">
                            <option value="">Seleccionar...</option>
                            <option value="carro">carro</option>
                            <option value="moto">moto</option>
                            <option value="movilidad reducida">movilidad reducida</option>
                        </select>
                    </td>
                    <td>
                        <select class="form-select" value="@row.ApartamentoId" @onchange="@(e => OnParqueaderoApartamentoChanged(row, e.Value?.ToString()))">
                            <option value="">Seleccionar Apartamento...</option>
                            @foreach (var a in allUnidades)
                            {
                                <option value="@((long)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.TorreId" disabled>
                            <option value="0">N/A</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.ConjuntoId" disabled>
                            <option value="">N/A</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@((long?)c.ConjuntoId)">@c.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "visitantes")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex flex-wrap gap-3 align-items-end">
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Estado</label>
                        <select class="form-select form-select-sm" @bind="filtroEstadoVis">
                            <option value="">Todos</option>
                            <option value="ocupado">Ocupado</option>
                            <option value="disponible">Disponible</option>
                        </select>
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Tipo</label>
                        <select class="form-select form-select-sm" @bind="filtroTipoVis">
                            <option value="">Todos</option>
                            <option value="carro">Carro</option>
                            <option value="moto">Moto</option>
                            <option value="movilidad reducida">Movilidad Reducida</option>
                        </select>
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Apartamento</label>
                        <select class="form-select form-select-sm" @bind="filtroAptoVis">
                            <option value="0">Todos</option>
                            @foreach (var a in allUnidades)
                            {
                                <option value="@a.ApartamentoId">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Torre</label>
                        <select class="form-select form-select-sm" @bind="filtroTorreVis">
                            <option value="0">Todas</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </div>
                    <div style="width: 200px;">
                        <label class="form-label fw-bold small text-muted mb-1">Filtrar por Conjunto</label>
                        <select class="form-select form-select-sm" @bind="filtroConjuntoVis">
                            <option value="0">Todos</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@c.ConjuntoId">@c.Nombre</option>
                            }
                        </select>
                    </div>
                </div>
            </div>

            <EntityTable TItem="ParqueaderoVisitante"
                         Title="Registro de Visitantes"
                         Headers='new() { "Tipo", "Placa", "Ocupado", "Apartamento Visitado", "Torre", "Conjunto" }'
                         Items="FilteredVisitantesRows"
                         ShowReportButton="true" ReportEntity="visitantes" RequiresDateRange="true"
                         OnAddRow='() => AddRow(visitanteRows)' OnSaveRow='SaveVisitante'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.Tipo">
                            <option value="">Seleccionar...</option>
                            <option value="carro">Carro</option>
                            <option value="moto">Moto</option>
                            <option value="movilidad reducida">Movilidad Reducida</option>
                        </select>
                    </td>
                    <td><input type="text" class="form-control" @bind="row.Placa" /></td>
                    <td class="text-center">
                        <div class="form-check form-switch mt-1 d-inline-block">
                            <input class="form-check-input" type="checkbox" @bind="row.Ocupado" />
                        </div>
                    </td>
                    <td>
                        <select class="form-select" value="@row.ApartamentoId" @onchange="@(e => OnApartamentoVisitanteChanged(row, e.Value?.ToString()))">
                            <option value="">Seleccionar Apartamento...</option>
                            @foreach (var a in allUnidades)
                            {
                                <option value="@((long)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.TorreId">
                            <option value="0">N/A</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.ConjuntoId">
                            <option value="0">N/A</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@((int)c.ConjuntoId)">@c.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
                <ExtraActionsTemplate Context="row">
                    <button type="button" class="btn btn-warning btn-sm me-1" title="Liberar" @onclick="() => LiberarVisitante(row)">
                        <i class="bi bi-unlock"></i> Liberar
                    </button>
                </ExtraActionsTemplate>
            </EntityTable>
        }
        else if (activeTab == "cuartoutil")
        {
            <div class="card mb-4 border-0 shadow-sm">
                <div class="card-body p-3 bg-light rounded-3 d-flex flex-wrap gap-3 align-items-end">
                    <div style="width: 180px;">
                        <label class="form-label fw-bold small text-muted mb-1">Estado</label>
                        <select class="form-select form-select-sm" @bind="filtroEstadoCU">
                            <option value="">Todos</option>
                            <option value="disponible">Disponible</option>
                            <option value="asignado">Asignado</option>
                            <option value="en mantenimiento">En mantenimiento</option>
                            <option value="inactivo">Inactivo</option>
                        </select>
                    </div>
                    <div style="width: 150px;">
                        <label class="form-label fw-bold small text-muted mb-1">Torre</label>
                        <select class="form-select form-select-sm" @bind="filtroTorreCU">
                            <option value="0">Todas</option>
                            @foreach (var t in allTorres) { <option value="@t.TorreId">@t.Nombre</option> }
                        </select>
                    </div>
                    <div style="width: 150px;">
                        <label class="form-label fw-bold small text-muted mb-1">Conjunto</label>
                        <select class="form-select form-select-sm" @bind="filtroConjuntoCU">
                            <option value="0">Todos</option>
                            @foreach (var c in allConjuntos) { <option value="@c.ConjuntoId">@c.Nombre</option> }
                        </select>
                    </div>
                    <div style="width: 180px;">
                        <label class="form-label fw-bold small text-muted mb-1">Apartamento</label>
                        <select class="form-select form-select-sm" @bind="filtroAptoCU">
                            <option value="0">Todos</option>
                            @foreach (var a in allUnidades) { <option value="@a.ApartamentoId">@a.Numero</option> }
                        </select>
                    </div>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => { filtroEstadoCU=string.Empty; filtroTorreCU=0; filtroConjuntoCU=0; filtroAptoCU=0; }">
                        <i class="bi bi-x-circle"></i> Limpiar
                    </button>
                </div>
            </div>
            <EntityTable TItem="CuartoUtil"
                         Title="Cuartos Útiles"
                         Headers='new() { "Número", "Estado", "Apartamento", "Torre", "Conjunto" }'
                         Items="FilteredCuartoUtilRows"
                         OnAddRow='() => AddRow(cuartoUtilRows)' OnSaveRow='SaveCuartoUtil'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.CuartoUtilNumero" placeholder="Ej: CU-01" /></td>
                    <td>
                        <select class="form-select" @bind="row.Estado">
                            <option value="">Seleccionar...</option>
                            <option value="disponible">Disponible</option>
                            <option value="asignado">Asignado</option>
                            <option value="en mantenimiento">En mantenimiento</option>
                            <option value="inactivo">Inactivo</option>
                        </select>
                    </td>
                    <td>
                        <select class="form-select" value="@row.ApartamentoId" @onchange="@(e => OnCuartoUtilApartamentoChanged(row, e.Value?.ToString()))">
                            <option value="">Sin asignar</option>
                            @foreach (var a in allUnidades)
                            {
                                <option value="@((long)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.TorreId" disabled>
                            <option value="0">N/A</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@((long)t.TorreId)">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.ConjuntoId" disabled>
                            <option value="">N/A</option>
                            @foreach (var c in allConjuntos)
                            {
                                <option value="@((long?)c.ConjuntoId)">@c.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }

    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }

    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
        private string activeTab = "ingresos";
    private int currentUserId;
    private int filtroVigilanteBit = 0;
    private DateTime? filtroFechaInicioBit;
    private DateTime? filtroFechaFinBit;
    private string filtroTipoPar = "";
    private int filtroTorrePar = 0;
    private int filtroConjuntoPar = 0;
    private long filtroAptoPar = 0;

    private List<Ingreso> ingresoRows = new();
    private List<BitacoraVigilancia> bitacoraRows = new();
    private List<Parqueadero> parqueaderoRows = new();
    private List<ParqueaderoVisitante> visitanteRows = new();

    private List<Apartamento> allUnidades = new();
    private List<Usuario> allVigilantes = new();
    private List<Torre> allTorres = new();
    private List<Conjunto> allConjuntos = new();

    private string filtroTipoIng = "";
    private DateTime? filtroFechaIng;
    private long filtroAptoIng = 0;

    private List<Ingreso> FilteredIngresoRows
    {
        get
        {
            var query = ingresoRows.AsEnumerable();
            if (!string.IsNullOrEmpty(filtroTipoIng)) query = query.Where(i => i.IngresoId == 0 || i.Tipo.Equals(filtroTipoIng, StringComparison.OrdinalIgnoreCase));
            if (filtroFechaIng.HasValue) query = query.Where(i => i.IngresoId == 0 || i.FechaHoraIngreso.Date == filtroFechaIng.Value.Date);
            if (filtroAptoIng != 0) query = query.Where(i => i.IngresoId == 0 || i.ApartamentoId == filtroAptoIng);
            return query.ToList();
        }
    }

    private List<CuartoUtil> cuartoUtilRows = new();
    private string filtroEstadoCU = "";
    private int filtroTorreCU = 0;
    private int filtroConjuntoCU = 0;
    private long filtroAptoCU = 0;

    // Filtros para visitantes
    private string filtroEstadoVis = "";
    private string filtroTipoVis = "";
    private long filtroAptoVis = 0;
    private int filtroTorreVis = 0;
    private int filtroConjuntoVis = 0;

        private List<BitacoraVigilancia> FilteredBitacoraRows
    {
        get
        {
            var query = bitacoraRows.AsEnumerable();
            if (filtroVigilanteBit != 0) query = query.Where(b => b.BitacoraId == 0 || b.VigilanteId == filtroVigilanteBit);
            if (filtroFechaInicioBit.HasValue) query = query.Where(b => b.BitacoraId == 0 || b.FechaHora.Date >= filtroFechaInicioBit.Value.Date);
            if (filtroFechaFinBit.HasValue) query = query.Where(b => b.BitacoraId == 0 || b.FechaHora.Date <= filtroFechaFinBit.Value.Date);
            return query.ToList();
        }
    }

        private List<Parqueadero> FilteredParqueaderoRows
    {
        get
        {
            var query = parqueaderoRows.AsEnumerable();
            if (!string.IsNullOrEmpty(filtroTipoPar)) query = query.Where(p => p.ParqueaderoId == 0 || p.Tipo.Equals(filtroTipoPar, StringComparison.OrdinalIgnoreCase));
            if (filtroTorrePar != 0) query = query.Where(p => p.ParqueaderoId == 0 || p.TorreId == filtroTorrePar);
            if (filtroConjuntoPar != 0) query = query.Where(p => p.ParqueaderoId == 0 || p.ConjuntoId == filtroConjuntoPar);
            if (filtroAptoPar != 0) query = query.Where(p => p.ParqueaderoId == 0 || p.ApartamentoId == filtroAptoPar);
            return query.ToList();
        }
    }

    private List<ParqueaderoVisitante> FilteredVisitantesRows
    {
        get
        {
            var query = visitanteRows.AsEnumerable();

            if (!string.IsNullOrEmpty(filtroEstadoVis))
            {
                if (filtroEstadoVis == "ocupado")
                {
                    query = query.Where(v => v.ParqueaderoVisitanteId == 0 || v.Ocupado);
                }
                else if (filtroEstadoVis == "disponible")
                {
                    query = query.Where(v => v.ParqueaderoVisitanteId == 0 || !v.Ocupado);
                }
            }

            if (!string.IsNullOrEmpty(filtroTipoVis))
            {
                query = query.Where(v => v.ParqueaderoVisitanteId == 0 || v.Tipo?.Equals(filtroTipoVis, StringComparison.OrdinalIgnoreCase) == true);
            }

            if (filtroAptoVis != 0)
            {
                query = query.Where(v => v.ParqueaderoVisitanteId == 0 || v.ApartamentoId == filtroAptoVis);
            }

            if (filtroTorreVis != 0)
            {
                query = query.Where(v => v.ParqueaderoVisitanteId == 0 || v.TorreId == filtroTorreVis);
            }

            if (filtroConjuntoVis != 0)
            {
                query = query.Where(v => v.ParqueaderoVisitanteId == 0 || v.ConjuntoId == filtroConjuntoVis);
            }

            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
                if (idClaim != null) int.TryParse(idClaim.Value, out currentUserId);
            }

            ingresoRows = await Http.GetFromJsonAsync<List<Ingreso>>("api/ingresos") ?? new();
            bitacoraRows = await Http.GetFromJsonAsync<List<BitacoraVigilancia>>("api/bitacora") ?? new();
                        parqueaderoRows = await Http.GetFromJsonAsync<List<Parqueadero>>("api/parqueaderos") ?? new();
            
            // Map names for search
            foreach(var p in parqueaderoRows) {
                p.TorreNombre = allTorres.FirstOrDefault(t => t.TorreId == p.TorreId)?.Nombre ?? "";
                p.ConjuntoNombre = allConjuntos.FirstOrDefault(c => c.ConjuntoId == p.ConjuntoId)?.Nombre ?? "";
            }
            visitanteRows = await Http.GetFromJsonAsync<List<ParqueaderoVisitante>>("api/visitantes") ?? new();

            allUnidades = await Http.GetFromJsonAsync<List<Apartamento>>("api/apartamentos") ?? new();

            // FIltrar vigilantes
            var usus = await Http.GetFromJsonAsync<List<Usuario>>("api/usuarios") ?? new();
            allVigilantes = usus.Where(u => u.RolId == 1).ToList();

            allTorres = await Http.GetFromJsonAsync<List<Torre>>("api/torres") ?? new();
                                    allConjuntos = await Http.GetFromJsonAsync<List<Conjunto>>("api/conjuntos") ?? new();
            
            // Map names for search
            foreach(var p in parqueaderoRows) {
                p.TorreNombre = allTorres.FirstOrDefault(t => t.TorreId == p.TorreId)?.Nombre ?? "";
                p.ConjuntoNombre = allConjuntos.FirstOrDefault(c => c.ConjuntoId == p.ConjuntoId)?.Nombre ?? "";
            }

            foreach (var ing in ingresoRows)
            {
                if (ing.ApartamentoId.HasValue)
                {
                    var apto = allUnidades.FirstOrDefault(a => a.ApartamentoId == ing.ApartamentoId);
                    if (apto != null)
                    {
                        var torre = allTorres.FirstOrDefault(t => t.TorreId == apto.TorreId);
                        if (torre != null) ing.ConjuntoId = torre.ConjuntoId;
                    }
                }
            }

            cuartoUtilRows = await Http.GetFromJsonAsync<List<CuartoUtil>>("api/cuartosutil") ?? new();

            if (ingresoRows.Count == 0) ingresoRows.Add(new Ingreso { FechaHoraIngreso = DateTime.Now });
            if (bitacoraRows.Count == 0) bitacoraRows.Add(new BitacoraVigilancia { FechaHora = DateTime.Now, VigilanteId = currentUserId });
            if (parqueaderoRows.Count == 0) parqueaderoRows.Add(new Parqueadero());
            if (visitanteRows.Count == 0) visitanteRows.Add(new ParqueaderoVisitante { FechaHoraIngreso = DateTime.Now });
            if (cuartoUtilRows.Count == 0) cuartoUtilRows.Add(new CuartoUtil());
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
            if (ingresoRows.Count == 0) ingresoRows.Add(new Ingreso { FechaHoraIngreso = DateTime.Now });
            if (bitacoraRows.Count == 0) bitacoraRows.Add(new BitacoraVigilancia { FechaHora = DateTime.Now, VigilanteId = currentUserId });
            if (parqueaderoRows.Count == 0) parqueaderoRows.Add(new Parqueadero());
            if (visitanteRows.Count == 0) visitanteRows.Add(new ParqueaderoVisitante { FechaHoraIngreso = DateTime.Now });
            if (cuartoUtilRows.Count == 0) cuartoUtilRows.Add(new CuartoUtil());
        }
        
    }

