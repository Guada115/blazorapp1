    private void OnParqueaderoApartamentoChanged(Parqueadero row, string? value)
    {
        if (string.IsNullOrEmpty(value) || !long.TryParse(value, out long aptoId))
        {
            row.ApartamentoId = null;
            row.TorreId = 0;
            row.ConjuntoId = null;
        }
        else
        {
            row.ApartamentoId = aptoId;
            var apto = allUnidades.FirstOrDefault(a => a.ApartamentoId == aptoId);
            if (apto != null)
            {
                row.TorreId = apto.TorreId;
                var t = allTorres.FirstOrDefault(x => x.TorreId == apto.TorreId);
                if (t != null)
                {
                    row.ConjuntoId = t.ConjuntoId;
                }
            }
        }
    }

    private void AddRow<T>(List<T> target) where T : new()
    {
        var newItem = new T();
        if (newItem is BitacoraVigilancia b)
        {
            b.VigilanteId = currentUserId;
            b.FechaHora = DateTime.Now;
        }
        else if (newItem is Ingreso i)
        {
            i.FechaHoraIngreso = DateTime.Now;
        }
        else if (newItem is ParqueaderoVisitante v)
        {
            v.FechaHoraIngreso = DateTime.Now;
        }
        target.Add(newItem);
        JS.InvokeVoidAsync("autoResizeTextareas");
    }

