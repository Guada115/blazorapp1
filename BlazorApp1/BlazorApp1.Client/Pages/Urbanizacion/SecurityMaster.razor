@page "/urbanizacion/seguridad"
@rendermode InteractiveWebAssembly
@attribute [Authorize(Roles = "1,3")]
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Seguridad & Acceso - Apex Housing</PageTitle>

<div class="container-fluid py-4 animate-up">
    <div class="d-flex justify-content-between align-items-end mb-4 page-header">
        <div>
            <h1 class="fw-bold mb-1">Seguridad & Acceso</h1>
            <p class="text-muted mb-0">Control de entradas, bitácora de vigilancia y gestión de parqueaderos.</p>
        </div>
    </div>

    <!-- Tab Navigation -->
    <ul class="nav nav-pills mb-4 p-2 rounded-3 shadow-sm d-inline-flex border overflow-auto flex-nowrap w-100" style="background-color: var(--card-bg); border-color: rgba(255,255,255,0.05) !important;">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "ingresos" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("ingresos")'>
                <i class="bi bi-door-open me-2"></i> Ingresos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "bitacora" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("bitacora")'>
                <i class="bi bi-journal-text me-2"></i> Bitácora
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "parqueadero" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("parqueadero")'>
                <i class="bi bi-p-square me-2"></i> Parqueaderos
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "visitantes" ? "active" : "") fw-semibold px-4 text-nowrap" @onclick='() => SetTab("visitantes")'>
                <i class="bi bi-p-square-fill me-2"></i> Visitantes
            </button>
        </li>
    </ul>

    <!-- Tab Content -->
    <div class="tab-content transition-fade">
        @if (activeTab == "ingresos")
        {
            <EntityTable TItem="Ingreso"
                         Title="Registro de Ingresos"
                         Headers='new() { "Tipo", "Nombre", "Documento", "Ingreso", "Salida", "Apartamento", "Torre", "Observaciones" }'
                         Items="ingresoRows"
                         ShowReportButton="true" ReportEntity="ingresos" RequiresDateRange="true"
                         OnAddRow='() => AddRow(ingresoRows)' OnSaveRow='SaveIngreso'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Tipo" placeholder="Tipo" /></td>
                    <td><input type="text" class="form-control" @bind="row.NombrePersona" placeholder="Nombre" /></td>
                    <td><input type="text" class="form-control" @bind="row.Documento" placeholder="Doc" /></td>
                    <td><input type="datetime-local" class="form-control" @bind="row.FechaHoraIngreso" /></td>
                    <td><input type="datetime-local" class="form-control" @bind="row.FechaHoraSalida" /></td>
                    <td>
                        <select class="form-select" value="@row.ApartamentoId" @onchange="@(e => OnApartamentoChanged(row, e.Value?.ToString()))">
                            <option value="">Seleccionar...</option>
                            @foreach (var a in allUnidades)
                            {
                                <option value="@((int)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.TorreId" disabled>
                            <option value="0">N/A</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                    <td>
                        <textarea class="form-control" rows="1" @bind="row.Observaciones" placeholder="Observaciones..." 
                                  style="resize:none; overflow:hidden; min-height: 38px;"
                                  oninput="this.style.height = 'auto'; this.style.height = (this.scrollHeight) + 'px';"></textarea>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "bitacora")
        {
            <EntityTable TItem="BitacoraVigilancia"
                         Title="Registros de Vigilancia (Bitácora)"
                         Headers='new() { "Vigilante", "Fecha Hora", "Observación" }'
                         Items="bitacoraRows"
                         ShowReportButton="true" ReportEntity="bitacora" RequiresDateRange="true"
                         OnAddRow='() => AddRow(bitacoraRows)' OnSaveRow='SaveBitacora'>
                <RowTemplate Context="row">
                    <td>
                        <select class="form-select" @bind="row.VigilanteId">
                            <option value="0">Seleccionar Vigilante...</option>
                            @foreach (var v in allVigilantes)
                            {
                                <option value="@v.UsuarioId">@v.Nombre</option>
                            }
                        </select>
                    </td>
                    <td><input type="datetime-local" class="form-control" @bind="row.FechaHora" /></td>
                    <td>
                        <textarea class="form-control" rows="1" @bind="row.Observacion" placeholder="Observación..." 
                                  style="resize:none; overflow:hidden; min-height: 38px;"
                                  oninput="this.style.height = 'auto'; this.style.height = (this.scrollHeight) + 'px';"></textarea>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "parqueadero")
        {
            <EntityTable TItem="Parqueadero"
                         Title="Espacios de Parqueo"
                         Headers='new() { "Tipo", "Número", "Torre" }'
                         Items="parqueaderoRows"
                         ShowReportButton="true" ReportEntity="parqueaderos"
                         OnAddRow='() => AddRow(parqueaderoRows)' OnSaveRow='SaveParqueadero'>
                <RowTemplate Context="row">
                    <td><input type="text" class="form-control" @bind="row.Tipo" placeholder="Tipo" /></td>
                    <td><input type="text" class="form-control" @bind="row.Numero" placeholder="Número" /></td>
                    <td>
                        <select class="form-select" @bind="row.TorreId">
                            <option value="0">Seleccionar Torre...</option>
                            @foreach (var t in allTorres)
                            {
                                <option value="@t.TorreId">@t.Nombre</option>
                            }
                        </select>
                    </td>
                </RowTemplate>
            </EntityTable>
        }
        else if (activeTab == "visitantes")
        {
            <EntityTable TItem="ParqueaderoVisitante"
                         Title="Registro de Visitantes"
                         Headers='new() { "Tipo", "Placa", "Ocupado", "Apartamento", "Torre", "Conjunto" }'
                         Items="visitanteRows"
                         ShowReportButton="true" ReportEntity="visitantes" RequiresDateRange="true"
                         OnAddRow='() => AddRow(visitanteRows)' OnSaveRow='SaveVisitante'>
                <RowTemplate Context="row">
                    @{
                        var t = allUnidades.FirstOrDefault(a => a.ApartamentoId == row.ApartamentoId) is Apartamento apto 
                            ? allTorres.FirstOrDefault(x => x.TorreId == apto.TorreId) 
                            : null;
                        var c = t != null ? allConjuntos.FirstOrDefault(x => x.ConjuntoId == t.ConjuntoId) : null;
                    }
                    <td>
                        <select class="form-select" @bind="row.Tipo">
                            <option value="">Seleccionar...</option>
                            <option value="carro">Carro</option>
                            <option value="moto">Moto</option>
                            <option value="movilidad reducida">Movilidad Reducida</option>
                        </select>
                    </td>
                    <td><input type="text" class="form-control" @bind="row.Placa" /></td>
                    <td class="text-center">
                        <div class="form-check form-switch mt-1 d-inline-block">
                            <input class="form-check-input" type="checkbox" @bind="row.Ocupado" />
                        </div>
                    </td>
                    <td>
                        <select class="form-select" @bind="row.ApartamentoId">
                            <option value="">Seleccionar Apartamento...</option>
                            @foreach (var a in allUnidades)
                            {
                                <option value="@((long)a.ApartamentoId)">@a.Numero - @a.Tipo</option>
                            }
                        </select>
                    </td>
                    <td>
                        <input type="text" class="form-control" value="@(t?.Nombre ?? "N/A")" readonly disabled />
                    </td>
                    <td>
                        <input type="text" class="form-control" value="@(c?.Nombre ?? "N/A")" readonly disabled />
                    </td>
                </RowTemplate>
                <ExtraActionsTemplate Context="row">
                    <button type="button" class="btn btn-warning btn-sm me-1" title="Liberar" @onclick="() => LiberarVisitante(row)">
                        <i class="bi bi-unlock"></i> Liberar
                    </button>
                </ExtraActionsTemplate>
            </EntityTable>
        }
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: var(--text-muted);
        transition: all 0.3s ease;
        border-radius: var(--radius-sm);
    }
    
    .nav-pills .nav-link.active {
        box-shadow: var(--shadow-md);
    }
    
    .transition-fade {
        animation: fadeIn 0.4s ease-out;
    }
</style>

@code {
    private string activeTab = "ingresos";
    
    private List<Ingreso> ingresoRows = new();
    private List<BitacoraVigilancia> bitacoraRows = new();
    private List<Parqueadero> parqueaderoRows = new();
    private List<ParqueaderoVisitante> visitanteRows = new();
    
    private List<Apartamento> allUnidades = new();
    private List<Usuario> allVigilantes = new();
    private List<Torre> allTorres = new();
    private List<Conjunto> allConjuntos = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ingresoRows = await Http.GetFromJsonAsync<List<Ingreso>>("api/ingresos") ?? new();
            bitacoraRows = await Http.GetFromJsonAsync<List<BitacoraVigilancia>>("api/bitacora") ?? new();
            parqueaderoRows = await Http.GetFromJsonAsync<List<Parqueadero>>("api/parqueaderos") ?? new();
            visitanteRows = await Http.GetFromJsonAsync<List<ParqueaderoVisitante>>("api/visitantes") ?? new();

            allUnidades = await Http.GetFromJsonAsync<List<Apartamento>>("api/apartamentos") ?? new();

            // FIltrar vigilantes
            var usus = await Http.GetFromJsonAsync<List<Usuario>>("api/usuarios") ?? new(); 
            allVigilantes = usus.Where(u => u.RolId == 1).ToList();

            allTorres = await Http.GetFromJsonAsync<List<Torre>>("api/torres") ?? new();
            allConjuntos = await Http.GetFromJsonAsync<List<Conjunto>>("api/conjuntos") ?? new();

            if (ingresoRows.Count == 0) ingresoRows.Add(new Ingreso { FechaHoraIngreso = DateTime.Now });
            if (bitacoraRows.Count == 0) bitacoraRows.Add(new BitacoraVigilancia { FechaHora = DateTime.Now });
            if (parqueaderoRows.Count == 0) parqueaderoRows.Add(new Parqueadero());
            if (visitanteRows.Count == 0) visitanteRows.Add(new ParqueaderoVisitante { FechaHoraIngreso = DateTime.Now });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
            if (ingresoRows.Count == 0) ingresoRows.Add(new Ingreso { FechaHoraIngreso = DateTime.Now });
            if (bitacoraRows.Count == 0) bitacoraRows.Add(new BitacoraVigilancia { FechaHora = DateTime.Now });
            if (parqueaderoRows.Count == 0) parqueaderoRows.Add(new Parqueadero());
            if (visitanteRows.Count == 0) visitanteRows.Add(new ParqueaderoVisitante { FechaHoraIngreso = DateTime.Now });
        }
    }

    private void SetTab(string tab) => activeTab = tab;

    private void AddRow<T>(List<T> target) where T : new()
    {
        target.Add(new T());
    }

    private void OnApartamentoChanged(Ingreso row, string? value)
    {
        if (string.IsNullOrEmpty(value) || !int.TryParse(value, out int aptoId))
        {
            row.ApartamentoId = null;
            row.TorreId = 0;
        }
        else
        {
            row.ApartamentoId = aptoId;
            var apto = allUnidades.FirstOrDefault(a => a.ApartamentoId == aptoId);
            if (apto != null)
            {
                row.TorreId = apto.TorreId;
            }
        }
    }

    private async Task SaveIngreso(Ingreso ingreso)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/ingresos", ingreso);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Ingreso>();
                if (saved != null) ingreso.IngresoId = saved.IngresoId;
                await JS.InvokeVoidAsync("alert", "Ingreso guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Ingreso: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar Ingreso. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveBitacora(BitacoraVigilancia bitacora)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/bitacora", bitacora);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<BitacoraVigilancia>();
                if (saved != null) bitacora.BitacoraId = saved.BitacoraId;
                await JS.InvokeVoidAsync("alert", "Registro de bitácora guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar bitácora: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar bitácora. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task SaveParqueadero(Parqueadero parqueadero)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/parqueaderos", parqueadero);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<Parqueadero>();
                if (saved != null) parqueadero.ParqueaderoId = saved.ParqueaderoId;
                await JS.InvokeVoidAsync("alert", "Parqueadero guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar Parqueadero: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar Parqueadero. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }

    private async Task LiberarVisitante(ParqueaderoVisitante visitante)
    {
        visitante.Placa = string.Empty;
        visitante.Ocupado = false;
        visitante.ApartamentoId = null;
        visitante.FechaHoraSalida = DateTime.Now; // Update exit time but hidden
        visitante.FechaHoraIngreso = null; // Clean for the next visitor
        await SaveVisitante(visitante);
    }

    private async Task SaveVisitante(ParqueaderoVisitante visitante)
    {
        // Se manejan automáticamente las fechas de ingreso y salida basados en estado Ocupado
        if (visitante.Ocupado && visitante.FechaHoraIngreso == null)
        {
            visitante.FechaHoraIngreso = DateTime.Now;
            visitante.FechaHoraSalida = null;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/visitantes", visitante);
            if (response.IsSuccessStatusCode)
            {
                var saved = await response.Content.ReadFromJsonAsync<ParqueaderoVisitante>();
                if (saved != null) visitante.ParqueaderoVisitanteId = saved.ParqueaderoVisitanteId;
                await JS.InvokeVoidAsync("alert", "Registro de visitante guardado correctamente!");
            }
            else
            {
                var errorMsg = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al guardar visitante: {errorMsg}");
                await JS.InvokeVoidAsync("alert", $"Error al guardar visitante. HTTP {response.StatusCode}:\n{errorMsg}");
            }
        }
        catch(Exception e)
        {
            await JS.InvokeVoidAsync("alert", $"Exception Client: {e.Message}");
        }
    }
}
